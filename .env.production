# Production Environment Configuration for Google Cloud Run
# Copy this file to .env and fill in your actual API keys

# API Configuration
API_KEY=honeypot-secret-key-12345
PORT=8080  # Cloud Run uses 8080 by default

# Groq - FAST & FREE (PRODUCTION) ⚡
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# LLM Provider Selection
LLM_PROVIDER=groq

# GUVI Hackathon Configuration
GUVI_CALLBACK_URL=https://hackathon.guvi.in/api/updateHoneyPotFinalResult

# Session Configuration (Production Optimized)
SESSION_TIMEOUT_SECONDS=300
MAX_CONVERSATION_TURNS=30
MIN_INTELLIGENCE_ITEMS=2

# Application Settings (Production)
LOG_LEVEL=INFO
ENVIRONMENT=production

# Optional: OpenAI (Backup)
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# Optional: Anthropic (Backup)
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
